# App
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://cvapi:cvapi@localhost:5432/cv_api_wp?schema=public

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Zavu
ZAVUDEV_API_KEY=zv_live_xxx
ZAVU_WEBHOOK_SECRET=whsec_xxx
# Set to true only in local dev when testing without signature
ZAVU_SKIP_SIGNATURE_VERIFICATION=false

# Auth (dashboard /admin)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Usuario inicial (seed): admin / trabajoya2024
ADMIN_USERNAME=admin
ADMIN_PASSWORD=trabajoya2024
ADMIN_EMAIL=admin@trabajoya.com

# TrabajoYa (creación de intakes vía WhatsApp)
TRABAJOYA_API_BASE_URL=https://trabajoya.rivasystems.dev
TRABAJOYA_INTAKE_API_KEY=

# ElevenLabs (text-to-speech para notas de voz WhatsApp)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Voice API (POST /api/voice/send)
VOICE_API_KEY=
PUBLIC_BASE_URL=https://api.example.com
